<% layout('layouts/boilerplates') %>
<div style="margin-top: 2rem; margin-bottom: 2rem;">
    <!-- Listing Image and Title -->
    <div style="margin-bottom: 2rem;">
        <div class="show-card">
            <img
                src="<%= listing.image.url %>"
                class="show-image"
                alt="<%= listing.title %>"
            />
        </div>
    </div>

    <!-- Main Content -->
    <div class="row">
        <div class="col-8" style="padding-right: 2rem;">
            <!-- Listing Title and Owner -->
            <div style="margin-bottom: 2rem;">
                <h1 style="color: #222; font-weight: 700; margin-bottom: 0.5rem;">
                    <%= listing.title %>
                </h1>
                <div style="display: flex; align-items: center; gap: 1rem; color: #717171;">
                    <i class="fa-solid fa-map-pin"></i>
                    <span><%= listing.location %>, <%= listing.country %></span>
                </div>
            </div>

            <!-- Listing Details Grid -->
            <div style="background: #f7f7f7; padding: 2rem; border-radius: 12px; margin-bottom: 2rem;">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 2rem;">
                    <div>
                        <p style="color: #717171; font-size: 0.9rem; margin-bottom: 0.5rem;">HOSTED BY</p>
                        <p style="font-weight: 600; color: #222;">
                            <i class="fa-solid fa-user-circle" style="color: #ff385c; margin-right: 0.5rem;"></i>
                            <%= listing.owner?.username || "Unknown Host" %>
                        </p>
                    </div>
                    <div>
                        <p style="color: #717171; font-size: 0.9rem; margin-bottom: 0.5rem;">PRICE PER NIGHT</p>
                        <p style="font-weight: 600; color: #222; font-size: 1.3rem;">
                            &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div style="margin-bottom: 2rem;">
                <h3 style="color: #222; font-weight: 600; margin-bottom: 1rem;">About This Listing</h3>
                <p style="color: #717171; line-height: 1.6; font-size: 1rem;">
                    <%= listing.description %>
                </p>
            </div>

            <hr style="margin: 2rem 0; border: none; border-top: 1px solid #ddd;">

            <!-- Reviews Section -->
            <div class="review-section">
                <% if(currUser) { %>
                    <h3 style="color: #222; font-weight: 600; margin-bottom: 1.5rem;">
                        <i class="fa-solid fa-star" style="color: #ff385c; margin-right: 0.5rem;"></i>
                        Leave a Review
                    </h3>
                    <div class="review-form">
                        <form
                            action="/listings/<%= listing.id %>/reviews"
                            method="post"
                            novalidate
                            class="needs-validation"
                        >
                            <!-- Star Rating -->
                           <div class="mb-3">
  <label class="form-label">Your Rating</label>

  <div class="star-rating">
    <input type="radio" id="star5" name="review[rating]" value="5" />
    <label for="star5" title="Amazing">★</label>

    <input type="radio" id="star4" name="review[rating]" value="4" />
    <label for="star4" title="Very good">★</label>

    <input type="radio" id="star3" name="review[rating]" value="3" />
    <label for="star3" title="Average">★</label>

    <input type="radio" id="star2" name="review[rating]" value="2" />
    <label for="star2" title="Not good">★</label>

    <input type="radio" id="star1" name="review[rating]" value="1" />
    <label for="star1" title="Terrible">★</label>
  </div>
</div>

                            <!-- Comments -->
                            <div class="mb-3">
                                <label for="comment" class="form-label">Your Comment</label>
                                <textarea
                                    name="review[comment]"
                                    id="comment"
                                    class="form-control"
                                    placeholder="Share your experience..."
                                    required
                                ></textarea>
                                <div class="invalid-feedback">Please add a comment for your review</div>
                            </div>

                            <button type="submit" class="btn btn-success">
                                <i class="fa-solid fa-paper-plane"></i> Submit Review
                            </button>
                        </form>
                    </div>
                <% } %>

                <!-- All Reviews -->
                <% if(listing.reviews && listing.reviews.length > 0) { %>
                    <div style="margin-top: 3rem;">
                        <h3 style="color: #222; font-weight: 600; margin-bottom: 1.5rem;">
                            <i class="fa-solid fa-comments" style="color: #ff385c; margin-right: 0.5rem;"></i>
                            Reviews (<%= listing.reviews.length %>)
                        </h3>
                        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                            <% for(review of listing.reviews) { %>
                                <div class="review-card">
                                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                        <div>
                                            <h5 class="card-title">
                                                <i class="fa-solid fa-user-circle" style="color: #ff385c; margin-right: 0.5rem;"></i>
                                                <%= review.author?.username || "Anonymous" %>
                                            </h5>
                                            <p class="starability-result card-text" data-rating="<%= review.rating %>">
                                                <i class="fa-solid fa-star" style="color: #ff385c;"></i> <%= review.rating %>/5 stars
                                            </p>
                                        </div>
                                        <% if(currUser && currUser._id.equals(review.author._id)) { %>
                                            <form 
                                                method="POST" 
                                                action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE"
                                                style="margin: 0;"
                                            >
                                                <button type="submit" class="btn btn-sm btn-danger" title="Delete review">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                    <p class="card-text">
                                        <%= review.comment %>
                                    </p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } else if(currUser) { %>
                    <div style="text-align: center; padding: 2rem; color: #717171;">
                        <i class="fa-solid fa-star" style="font-size: 2rem; color: #ddd; display: block; margin-bottom: 1rem;"></i>
                        <p>No reviews yet. Be the first to review!</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-4" style="padding-left: 2rem;">
            <div style="background: #f7f7f7; padding: 1.5rem; border-radius: 12px; position: sticky; top: 100px;">
                <div style="text-align: center; margin-bottom: 1.5rem;">
                    <h4 style="color: #222; font-weight: 600; margin-bottom: 1rem;">
                        &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>/night
                    </h4>
                    <button class="btn btn-success" style="width: 100%; margin-bottom: 1rem;">
                        <i class="fa-solid fa-calendar"></i> Reserve
                    </button>
                </div>

                <!-- Host Info -->
                <div style="border-top: 1px solid #ddd; padding-top: 1.5rem;">
                    <p style="color: #717171; font-size: 0.9rem; margin-bottom: 0.5rem;">HOSTED BY</p>
                    <p style="color: #222; font-weight: 600; font-size: 1.1rem;">
                        <%= listing.owner?.username || "Unknown Host" %>
                    </p>
                </div>

                <!-- Owner Actions -->
                <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
                    <div style="border-top: 1px solid #ddd; padding-top: 1.5rem; margin-top: 1.5rem;">
                        <p style="color: #717171; font-size: 0.85rem; margin-bottom: 1rem; font-weight: 600;">MANAGE LISTING</p>
                        <div style="display: flex; flex-direction: column; gap: 0.8rem;">
                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark" style="text-align: center;">
                                <i class="fa-solid fa-pen-to-square"></i> Edit Listing
                            </a>
                            <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" style="margin: 0;">
                                <button type="submit" class="btn btn-danger" style="width: 100%;" onclick="return confirm('Are you sure you want to delete this listing?');">
                                    <i class="fa-solid fa-trash"></i> Delete Listing
                                </button>
                            </form>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Add custom styles for star rating if needed -->
<style>
  .star-rating {
    display: flex;
    flex-direction: row-reverse;
    justify-content: start;
    gap: 5px;
  }

  .star-rating input {
    display: none;
  }

  .star-rating label {
    font-size: 2rem;
    color: #ddd;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  /* Hover effect */
  .star-rating label:hover,
  .star-rating label:hover ~ label {
    color: #fe424d;
  }

  /* Selected stars */
  .star-rating input:checked ~ label {
    color: #fe424d;
  }
  
    .btn-danger {
        background-color: #ff385c;
        color: #fff;
    }
    .btn-danger:hover {
        background-color: #e4364b;
    }
</style>